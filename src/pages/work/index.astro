---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlurImage from '../../components/BlurImage.astro';
import projects from '../../data/projects.yaml';
---

<BaseLayout title="Designbysoil – Work of Abdul Rehman Khawar">
  <section class="section">
    <div class="project-grid">
      {Object.entries(projects).map(([key, project]: [string, any]) => (
        <div>
          <a href={project.page}>
            <BlurImage
              src={`${project.thumbnail}?w=1000&h=1000${project.crop === 'faces' ? '&fit=crop&f=faces' : ''}`}
              class="project-grid-thumb"
            />
            <h3 style={`color:${project.color} !important;`}>{project.title}</h3>
            <div class="small">{project.toolkit}</div>
          </a>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style is:global>
  .project-grid .project-grid-thumb {
    border-radius: 8px;
    margin-bottom: 10px;
    height: 362px;
  }

  .project-grid .project-grid-thumb .blur-image__full {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1);
    opacity: 0.8;
    transition: ease .2s;
  }

  .project-grid > div:hover .blur-image__full {
    opacity: 1;
    filter: none;
  }
</style>
