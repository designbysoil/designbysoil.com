---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import projects from '../../../data/projects.yaml';
import ProjectHero from '../../../components/ProjectHero.astro';
import ProjectMeta from '../../../components/ProjectMeta.astro';
import ImageFullBleed from '../../../components/ImageFullBleed.astro';
import ImageCentered from '../../../components/ImageCentered.astro';
import GridFullCenter from '../../../components/GridFullCenter.astro';
import ProjectNextFooter from '../../../components/ProjectNextFooter.astro';

const project = projects.healthdesk;
---

<BaseLayout title="Meedan – Health Desk">
  <ProjectHero imageUrl={project.hero} title="Meedan – Health Desk" />
  <ProjectMeta toolkit={project.toolkit} color={project.color} />
  <ImageFullBleed imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/5T7gnpHKrGl5uJrIAiDxwc/0fce625561efde096f1577b7e9b89fd0/Health_Desk_-_Documentation_-_10.png" />
  <ImageFullBleed imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/5EoRZJLW9ErkeBJWjtUBmu/42d1f17cd2d9f048d255c6df09a38060/Health_Desk_-_Documentation_-_9.png" />
  <GridFullCenter
    fullImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/2fKCFGMj0jp526joi6JG3r/291057a93015e0a23aa098d79aa42688/health-desk-on-phone.jpg"
    centerImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/1ZONKtq1xp5fD0JCl2kCpD/274419aa44eb2432f98f1af6fdc456a4/health-desk-sourced.png"
    background="#002B31"
    reversed={true}
  />
  <ImageCentered imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/3fSsmQ9Cy8hynLpstV2hz8/a7777d705f6e19e3783c14fab0362ba5/Ask_a_question.png" />
  <ImageFullBleed imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/6QaJBneEp0Ohno3O87u1SM/825eb40d13d2278d5a29dc3e7837d178/healthdesk-homepage-v2.jpg" />
  <ImageCentered
    imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/5R1Yyh3gF8QDGkxzP3onyj/e0ec53874db3c53dc99e392d9eebf023/Home_-_Header_Redesign_-_15.png"
    align="bottom"
    imageClass="rounded-top"
  />
  <ImageCentered
    imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/1dQMhkMPmlxBIBPE5zPqRn/e13028cd4db03411a35e69096f6b8b2a/Entry.png"
    align="bottom"
    imageClass="rounded-top"
  />
  <ProjectNextFooter slot="footer" title={projects['guardias-da-resistencia-podcast'].title} url={projects['guardias-da-resistencia-podcast'].page} color={projects['guardias-da-resistencia-podcast'].color} />
</BaseLayout>
