---
---

<div class="hero-art" aria-hidden="true">
  <div class="hero-art__pair hero-art__pair--1">
    <div class="hero-art__shape hero-art__rect hero-art__rect--orange"></div>
    <div class="hero-art__shape hero-art__circle hero-art__circle--right"></div>
  </div>
  <div class="hero-art__pair hero-art__pair--2">
    <div class="hero-art__shape hero-art__rect hero-art__rect--pink"></div>
    <div class="hero-art__shape hero-art__circle hero-art__circle--upper"></div>
  </div>
  <div class="hero-art__pair hero-art__pair--3">
    <div class="hero-art__shape hero-art__rect hero-art__rect--blue"></div>
    <div class="hero-art__shape hero-art__circle hero-art__circle--lower"></div>
  </div>
</div>

<style>
  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 854 / 866;
    overflow: visible;
  }

  .hero-art__pair {
    position: absolute;
    inset: 0;
    animation-duration: 8s, 24s;
    animation-timing-function: cubic-bezier(0.95, 0, 0.05, 1);
    animation-iteration-count: infinite;
  }

  .hero-art__pair--1 {
    transform-origin: 75.4% 26.7%;
    animation-name: pair-rotate-1, pair-travel-1;
  }
  .hero-art__pair--2 {
    transform-origin: 29% 31%;
    animation-name: pair-rotate-2, pair-travel-2;
  }
  .hero-art__pair--3 {
    transform-origin: 64.9% 75.9%;
    animation-name: pair-rotate-3, pair-travel-3;
  }

  .hero-art__shape {
    position: absolute;
    translate: -50% -50%;
    opacity: 0;
    transition: opacity 2s ease;
  }

  .hero-art.is-loaded .hero-art__shape {
    opacity: 1;
  }

  .hero-art__rect--orange  { transition-delay: 0.20s; }
  .hero-art__circle--right { transition-delay: 0.35s; }
  .hero-art__rect--pink    { transition-delay: 0.50s; }
  .hero-art__circle--upper { transition-delay: 0.65s; }
  .hero-art__rect--blue    { transition-delay: 0.80s; }
  .hero-art__circle--lower { transition-delay: 0.95s; }

  .hero-art__circle {
    border-radius: 50%;
    background: linear-gradient(
      0deg,
      rgba(0, 141, 94, 0) 0%,
      rgba(95, 158, 229, 1) 46.35%,
      rgba(255, 178, 178, 1) 78.13%,
      rgba(242, 222, 220, 1) 100%
    );
  }

  .hero-art__rect--orange {
    width: 39.84%;
    height: 18.69%;
    background: #ff864d;
    left: 69.9%;
    top: 19.1%;
    rotate: -148deg;
  }

  .hero-art__circle--right {
    width: 34.43%;
    height: 33.94%;
    left: 80.9%;
    top: 34.3%;
    rotate: 95.67deg;
  }

  .hero-art__rect--pink {
    width: 39.84%;
    height: 18.69%;
    background: #ff4d7e;
    left: 21.7%;
    top: 26.9%;
    rotate: 135.74deg;
  }

  .hero-art__rect--blue {
    width: 39.84%;
    height: 18.69%;
    background: #0055dd;
    left: 71.0%;
    top: 78.4%;
    rotate: -102.09deg;
  }

  .hero-art__circle--lower {
    width: 34.43%;
    height: 33.94%;
    left: 58.7%;
    top: 73.4%;
    rotate: 24.88deg;
  }

  .hero-art__circle--upper {
    width: 34.43%;
    height: 33.94%;
    left: 36.4%;
    top: 35.3%;
    rotate: -179.24deg;
  }

  /* Each pair makes one full revolution per 8s cycle, but the two
     intermediate hold angles differ per pair so the trio never reads
     as locked-step. */
  @keyframes pair-rotate-1 {
    0%,  25%  { rotate: 0deg; }
    30%, 60%  { rotate: 165deg; }
    65%, 95%  { rotate: 285deg; }
    100%      { rotate: 360deg; }
  }

  @keyframes pair-rotate-2 {
    0%,  25%  { rotate: 0deg; }
    30%, 60%  { rotate: -95deg; }
    65%, 95%  { rotate: -245deg; }
    100%      { rotate: -360deg; }
  }

  @keyframes pair-rotate-3 {
    0%,  25%  { rotate: 0deg; }
    30%, 60%  { rotate: 215deg; }
    65%, 95%  { rotate: 110deg; }
    100%      { rotate: 360deg; }
  }

  /* Clockwise arc travel: P1 → P2 → P3 → P1.
     Midpoints bow outward from the triangle centroid (~56%, 45%).
     Hold-snap-hold timing per 8s sub-segment mirrors pair-rotate
     (hold 0-6.67% / snap to mid 11.67-18.33% / snap to next vertex 23.33-40%),
     so the orbit snaps stay in lockstep with the rotation snaps. */
  @keyframes pair-travel-1 {
    0%,     8.33%   { translate: 0 0; }
    10%,    20%     { translate: -25.3% -5.6%; }
    21.67%, 41.67%  { translate: -46.4% 4.3%; }
    43.33%, 53.33%  { translate: -34.3% 32.3%; }
    55%,    75%     { translate: -10.5% 49.2%; }
    76.67%, 86.67%  { translate: 2% 28.1%; }
    88.33%, 100%    { translate: 0 0; }
  }

  @keyframes pair-travel-2 {
    0%,     8.33%   { translate: 0 0; }
    10%,    20%     { translate: 12.1% 28%; }
    21.67%, 41.67%  { translate: 35.9% 44.9%; }
    43.33%, 53.33%  { translate: 48.4% 23.8%; }
    55%,    75%     { translate: 46.4% -4.3%; }
    76.67%, 86.67%  { translate: 21.1% -9.9%; }
    88.33%, 100%    { translate: 0 0; }
  }

  @keyframes pair-travel-3 {
    0%,     8.33%   { translate: 0 0; }
    10%,    20%     { translate: 12.5% -21.1%; }
    21.67%, 41.67%  { translate: 10.5% -49.2%; }
    43.33%, 53.33%  { translate: -14.8% -54.8%; }
    55%,    75%     { translate: -35.9% -44.9%; }
    76.67%, 86.67%  { translate: -23.8% -16.9%; }
    88.33%, 100%    { translate: 0 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-art__pair {
      animation: none !important;
    }
    .hero-art__shape {
      animation: none !important;
      opacity: 1 !important;
      transition: none !important;
    }
  }

  @media screen and (max-width: 991px) {
    .hero-art {
      border-radius: 4px;
      max-width: 400px;
      margin: 30px auto 0;
    }
  }
</style>

<script>
  requestAnimationFrame(() => {
    document.querySelector('.hero-art')?.classList.add('is-loaded');
  });
</script>
