---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectNextFooter from '../../../components/ProjectNextFooter.astro';
import ProjectHero from '../../../components/ProjectHero.astro';
import ProjectMeta from '../../../components/ProjectMeta.astro';
import TextBlock from '../../../components/TextBlock.astro';
import ImageFullBleed from '../../../components/ImageFullBleed.astro';
import GridFull from '../../../components/GridFull.astro';
import ImageCentered from '../../../components/ImageCentered.astro';
import ImageCarouselWithText from '../../../components/ImageCarouselWithText.astro';
import projects from '../../../data/projects.yaml';

const project = projects['2020-misinfodemic-report'];
const coversSlides = project.covers;
---

<BaseLayout title={project.title}>
  <ProjectHero imageUrl={project.hero} title={project.title} />
  <TextBlock heading="" text="An interdisciplinary collection of reports and essays that seek to map the anotomy of a global pandemic." />
  <ProjectMeta client={project.client} toolkit={project.toolkit} />
  <ImageFullBleed imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/2ZuotuL4EURiH8Td8y3NSp/9f601a0b627d6daa7eb5490678d0b802/meedan-2020-misinfodemic-report_laptop.png" />
  <GridFull
    image1Url="https://images.ctfassets.net/2orm8gd3ce6v/4Yq7yVigaxGf5FKoWPHAjw/edcc747376c40ddf6d24ea01b9c3017a/Meedan_2020_Misinfodemic_Report_Covers_Tablet.png"
    image2Url="https://images.ctfassets.net/2orm8gd3ce6v/ir1nRTmmrM0HmOz1XU5Xh/0ac108d9c428fdeccf2f8535cc4994b1/Meedan_2020_Misinfodemic_Report_Covers.png"
  />
  <ImageCentered imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/5XBJpIEC3lcbnRjagIULsB/72030b1aa66c6d113c76b322f85b925d/meedan-2020-misinfodemic-report_landing-page.png" align="bottom" imageClass="rounded-top" />
  <ImageCentered imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/7nTNaPAIbouf1Wf1flXzXc/98807af7db28daae5a96f41077881a0b/meedan-2020-misinfodemic-report_web_report.png" align="bottom" imageClass="rounded-top" />
  <ImageCarouselWithText
    slides={coversSlides}
    heading="Report series"
    description="Template for projects featured in the podcast."
    perPage={3}
  />
  <ProjectNextFooter slot="footer" title={projects['qf'].title} url={projects['qf'].page} color={projects['qf'].color} />
</BaseLayout>
