---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroArt from '../components/HeroArt.astro';
import AvailabilityMarquee from '../components/AvailabilityMarquee.astro';
import projects from '../data/projects.yaml';
---

<BaseLayout title="Designbysoil – Work of Abdul Rehman Khawar">
  <section class="section section--availability">
    <AvailabilityMarquee />
  </section>
  <section class="section">
    <div class="main-grid homepage-hero">
      <div class="homepage-hero-content">
        <h1>Digital designer from Canada, working globally / remotely. Crafting purpose-driven brand experiences for screens.</h1>
      </div>
      <div class="homepage-hero-image">
        <HeroArt />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="project-list">
      <div class="item-header">Projects</div>
      {Object.entries(projects).map(([key, project]: [string, any]) => (
        <a href={project.page}>
          {project.title}
          <div class="media">
            <img src={project.thumbnail} />
          </div>
          <div class="toolkit small">
            {project.toolkit}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
