---
interface Props {
  slides: { image: string }[];
  heading?: string;
  description?: string;
  details?: string;
  border?: boolean;
  perPage?: number;
}

const { slides, heading, description, details, border = false, perPage = 3 } = Astro.props;
---

<section class="section">
  <div class="block-image">
    <div class="block-image-inner" style="padding-left: 0 !important;">
      {heading && (
        <div class="supporting-content">
          <div class="supporting-content-copy">
            <h3>{heading}</h3>
            <div class="type-detail">
              {description}
            </div>
          </div>
          {details && (
            <div class="supporting-content-details">
              <div class="small">
                {details}
              </div>
            </div>
          )}
        </div>
      )}

      <div class="marquee-carousel">
        <div class="marquee-carousel__track">
          {/* Original slides */}
          {slides.map((slide, i) => (
            <div
              class:list={["marquee-carousel__slide", { "marquee-carousel__slide--border": border }]}
              aria-label={`${i + 1} of ${slides.length}`}
              role="group"
            >
              <img
                sizes="(max-width: 479px) 100vw, (max-width: 767px) 50vw, 33vw"
                srcset={`${slide.image}?fl=progressive&q=90&w=500 500w, ${slide.image}?fl=progressive&q=90&w=800 800w, ${slide.image}?fl=progressive&q=90&w=1080 1080w, ${slide.image}?fl=progressive&q=90&w=1600 1600w`}
                src={`${slide.image}?fl=progressive`}
                alt=""
                loading="lazy"
              />
            </div>
          ))}
          {/* Duplicated slides for seamless loop */}
          {slides.map((slide, i) => (
            <div
              class:list={["marquee-carousel__slide", { "marquee-carousel__slide--border": border }]}
              aria-hidden="true"
            >
              <img
                sizes="(max-width: 479px) 100vw, (max-width: 767px) 50vw, 33vw"
                srcset={`${slide.image}?fl=progressive&q=90&w=500 500w, ${slide.image}?fl=progressive&q=90&w=800 800w, ${slide.image}?fl=progressive&q=90&w=1080 1080w, ${slide.image}?fl=progressive&q=90&w=1600 1600w`}
                src={`${slide.image}?fl=progressive`}
                alt=""
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .marquee-carousel {
    position: relative;
    overflow: visible;
    cursor: default;
  }

  .marquee-carousel__track {
    display: flex;
    gap: 1rem;
    will-change: transform;
  }

  .marquee-carousel__slide {
    flex: 0 0 calc((100% - 2rem) / 3);
    border-radius: 8px;
    overflow: hidden;
  }

  .marquee-carousel__slide--border {
    border: 1px solid #333;
  }

  .marquee-carousel__slide img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    pointer-events: none;
  }

  @media screen and (max-width: 767px) {
    .marquee-carousel__slide {
      flex: 0 0 calc((100% - 1rem) / 2);
    }
  }

  @media screen and (max-width: 479px) {
    .marquee-carousel__slide {
      flex: 0 0 85%;
    }
  }
</style>

<script>
  function initMarqueeCarousels() {
    document.querySelectorAll<HTMLElement>('.marquee-carousel').forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>('.marquee-carousel__track');
      if (!track) return;

      const baseSpeed = 1.4;
      const hoverSpeed = 0.4;
      let currentSpeed = baseSpeed;
      let targetSpeed = baseSpeed;
      let offset = 0;
      let singleSetWidth = 0;

      function measureSetWidth() {
        const slides = track!.querySelectorAll('.marquee-carousel__slide');
        const totalSlides = slides.length;
        const originalCount = totalSlides / 2;
        const gap = parseFloat(getComputedStyle(track!).gap) || 0;
        let width = 0;
        for (let i = 0; i < originalCount; i++) {
          width += (slides[i] as HTMLElement).offsetWidth + gap;
        }
        singleSetWidth = width;
      }

      function animate() {
        // Ease currentSpeed toward targetSpeed
        currentSpeed += (targetSpeed - currentSpeed) * 0.04;

        offset -= currentSpeed;

        if (offset <= -singleSetWidth) {
          offset += singleSetWidth;
        }

        track!.style.transform = `translateX(${offset}px)`;
        requestAnimationFrame(animate);
      }

      carousel.addEventListener('mouseenter', () => {
        targetSpeed = hoverSpeed;
      });

      carousel.addEventListener('mouseleave', () => {
        targetSpeed = baseSpeed;
        currentSpeed = baseSpeed;
      });

      measureSetWidth();
      requestAnimationFrame(animate);

      window.addEventListener('resize', () => {
        measureSetWidth();
      });
    });
  }

  initMarqueeCarousels();
</script>
