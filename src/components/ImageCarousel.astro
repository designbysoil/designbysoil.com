---
interface Props {
  slides: { image: string }[];
  border?: boolean;
}

const { slides, border = false } = Astro.props;
---

<section class="section">
  <div class:list={["carousel", { "carousel--border": border }]}>
    <div class="carousel__track">
      {slides.map((slide, i) => (
        <div
          class="carousel__slide"
          aria-label={`${i + 1} of ${slides.length}`}
          role="group"
        >
          <img
            sizes="(max-width: 479px) 100vw, (max-width: 767px) 95vw, (max-width: 991px) 92vw, 82vw"
            srcset={`${slide.image}?fl=progressive&q=90&w=500 500w, ${slide.image}?fl=progressive&q=90&w=800 800w, ${slide.image}?fl=progressive&q=90&w=1080 1080w, ${slide.image}?fl=progressive&q=90&w=1600 1600w, ${slide.image}?fl=progressive&q=90&w=2000 2000w, ${slide.image}?fl=progressive&q=90&w=2600 2600w, ${slide.image}?fl=progressive&q=90&w=3200 3200w, ${slide.image}?fl=progressive&q=90&w=3840 3840w`}
            src={`${slide.image}?fl=progressive`}
            alt=""
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel {
    position: relative;
    overflow: visible;
    cursor: grab;
  }

  .carousel.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .carousel__track {
    display: flex;
    align-items: stretch;
    gap: 60px;
    overflow: visible;
    will-change: transform;
  }

  .carousel.is-dragging .carousel__track {
    transition: none;
  }

  .carousel__slide {
    flex: none;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .carousel--border .carousel__slide {
    border: 1px solid #333;
  }

  .carousel__slide img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
  }
</style>

<script>
  function initCarousels() {
    document.querySelectorAll<HTMLElement>('.carousel').forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>('.carousel__track');
      if (!track) return;

      let isDragging = false;
      let startX = 0;
      let currentTranslate = 0;
      let prevTranslate = 0;
      let animationId: number;
      let currentIndex = 0;
      let velocity = 0;
      let lastX = 0;
      let lastTime = 0;

      const slides = track.querySelectorAll('.carousel__slide');
      const slideCount = slides.length;

      function getSlideWidth() {
        const slide = slides[0] as HTMLElement;
        if (!slide) return 0;
        const gap = parseFloat(getComputedStyle(track!).gap) || 0;
        return slide.offsetWidth + gap;
      }

      function setPositionByIndex() {
        const slideWidth = getSlideWidth();
        currentTranslate = -currentIndex * slideWidth;
        prevTranslate = currentTranslate;

        const speed = Math.abs(velocity);
        const duration = Math.min(0.35, Math.max(0.18, speed * 80));
        track!.style.transition = `transform ${duration}s cubic-bezier(0.22, 1, 0.36, 1)`;
        track!.style.transform = `translateX(${currentTranslate}px)`;
      }

      function animation() {
        track!.style.transform = `translateX(${currentTranslate}px)`;
        if (isDragging) animationId = requestAnimationFrame(animation);
      }

      function touchStart(e: PointerEvent) {
        isDragging = true;
        startX = e.clientX;
        lastX = e.clientX;
        lastTime = Date.now();
        velocity = 0;
        carousel.classList.add('is-dragging');
        track!.style.transition = 'none';
        animationId = requestAnimationFrame(animation);
        carousel.setPointerCapture(e.pointerId);
      }

      function touchMove(e: PointerEvent) {
        if (!isDragging) return;
        const now = Date.now();
        const dt = now - lastTime;
        if (dt > 0) {
          velocity = (e.clientX - lastX) / dt;
        }
        lastX = e.clientX;
        lastTime = now;
        const dx = e.clientX - startX;
        currentTranslate = prevTranslate + dx;
      }

      function touchEnd() {
        isDragging = false;
        cancelAnimationFrame(animationId);
        carousel.classList.remove('is-dragging');

        const slideWidth = getSlideWidth();
        const projected = currentTranslate + velocity * 180;
        const projectedIndex = Math.round(-projected / slideWidth);
        currentIndex = Math.max(0, Math.min(slideCount - 1, projectedIndex));

        setPositionByIndex();
      }

      carousel.addEventListener('pointerdown', touchStart);
      carousel.addEventListener('pointermove', touchMove);
      carousel.addEventListener('pointerup', touchEnd);
      carousel.addEventListener('pointercancel', touchEnd);

      carousel.addEventListener('contextmenu', (e) => {
        if (isDragging) e.preventDefault();
      });

      window.addEventListener('resize', () => {
        setPositionByIndex();
      });
    });
  }

  initCarousels();
</script>
