---
import BaseLayout from '../layouts/BaseLayout.astro';
import projects from '../data/projects.yaml';
---

<BaseLayout title="Designbysoil – Work of Abdul Rehman Khawar">
  <section class="section">
    <div class="availability">
      <div class="type-detail">
        <h3>Availability</h3>
        <p>I'm open for new opportunities and collaborations.<br><a href="mailto:mail@designbysoil.com">Get in touch.</a></p>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="main-grid homepage-hero">
      <div class="homepage-hero-content">
        <h1>Digital designer from Canada, working globally / remotely. Crafting purpose-driven brand experiences for screens.</h1>
      </div>
      <img class="homepage-hero-image" src="https://images.ctfassets.net/2orm8gd3ce6v/5aI4XuTk0yQpDLB2HyHqpm/63e24053cdbe55d56ca5844a2d5b2de5/designbysoil-homepage-hero.png" />
    </div>
  </section>

  <section class="section">
    <div class="project-list">
      <div class="item-header">Projects</div>
      {Object.entries(projects).map(([key, project]: [string, any]) => (
        <a href={project.page}>
          {project.title}
          <div class="media">
            <img src={project.thumbnail} />
          </div>
          <div class="toolkit small">
            {project.toolkit}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
