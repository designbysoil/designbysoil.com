---
interface Props {
  slides: { image: string }[];
  imageClass?: string;
}

const { slides, imageClass } = Astro.props;
---

<section class="section">
  <div class="fullbleed-carousel">
    <div class="fullbleed-carousel__track">
      {slides.map((slide, i) => (
        <div
          class="fullbleed-carousel__slide"
          aria-label={`${i + 1} of ${slides.length}`}
          role="group"
        >
          <img
            src={slide.image}
            sizes="(max-width: 479px) 92vw, (max-width: 767px) 95vw, (max-width: 991px) 92vw, 91vw"
            srcset={`${slide.image}?fl=progressive&q=90&w=500 500w, ${slide.image}?fl=progressive&q=90&w=800 800w, ${slide.image}?fl=progressive&q=90&w=1080 1080w, ${slide.image} 1318w`}
            alt=""
            loading="lazy"
            class={imageClass}
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .fullbleed-carousel {
    position: relative;
    overflow: hidden;
    cursor: grab;
  }

  .fullbleed-carousel.is-dragging {
    cursor: grabbing;
    user-select: none;
  }

  .fullbleed-carousel__track {
    display: flex;
    will-change: transform;
  }

  .fullbleed-carousel.is-dragging .fullbleed-carousel__track {
    transition: none;
  }

  .fullbleed-carousel__slide {
    flex: none;
    width: 100%;
  }

  .fullbleed-carousel__slide img {
    display: block;
    width: 100%;
    height: auto;
    pointer-events: none;
  }
</style>

<script>
  function initFullbleedCarousels() {
    document.querySelectorAll<HTMLElement>('.fullbleed-carousel').forEach((carousel) => {
      const track = carousel.querySelector<HTMLElement>('.fullbleed-carousel__track');
      if (!track) return;

      let isDragging = false;
      let startX = 0;
      let currentTranslate = 0;
      let prevTranslate = 0;
      let animationId: number;
      let currentIndex = 0;
      let velocity = 0;
      let lastX = 0;
      let lastTime = 0;
      let autoplayTimer: number;

      const slides = track.querySelectorAll('.fullbleed-carousel__slide');
      const slideCount = slides.length;

      function getSlideWidth() {
        return carousel.offsetWidth;
      }

      function goToIndex(animate = true) {
        const slideWidth = getSlideWidth();
        currentTranslate = -currentIndex * slideWidth;
        prevTranslate = currentTranslate;
        if (animate) {
          const speed = Math.abs(velocity);
          const duration = Math.min(0.35, Math.max(0.18, speed * 80));
          track!.style.transition = `transform ${duration}s cubic-bezier(0.22, 1, 0.36, 1)`;
        } else {
          track!.style.transition = 'none';
        }
        track!.style.transform = `translateX(${currentTranslate}px)`;
      }

      function autoplayNext() {
        velocity = 0.5;
        currentIndex = (currentIndex + 1) % slideCount;
        track!.style.transition = 'transform 0.6s cubic-bezier(0.22, 1, 0.36, 1)';
        const slideWidth = getSlideWidth();
        currentTranslate = -currentIndex * slideWidth;
        prevTranslate = currentTranslate;
        track!.style.transform = `translateX(${currentTranslate}px)`;
      }

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = window.setInterval(autoplayNext, 3000);
      }

      function stopAutoplay() {
        clearInterval(autoplayTimer);
      }

      function animation() {
        track!.style.transform = `translateX(${currentTranslate}px)`;
        if (isDragging) animationId = requestAnimationFrame(animation);
      }

      function touchStart(e: PointerEvent) {
        isDragging = true;
        stopAutoplay();
        startX = e.clientX;
        lastX = e.clientX;
        lastTime = Date.now();
        velocity = 0;
        carousel.classList.add('is-dragging');
        track!.style.transition = 'none';
        animationId = requestAnimationFrame(animation);
        carousel.setPointerCapture(e.pointerId);
      }

      function touchMove(e: PointerEvent) {
        if (!isDragging) return;
        const now = Date.now();
        const dt = now - lastTime;
        if (dt > 0) {
          velocity = (e.clientX - lastX) / dt;
        }
        lastX = e.clientX;
        lastTime = now;
        const dx = e.clientX - startX;
        currentTranslate = prevTranslate + dx;
      }

      function touchEnd() {
        isDragging = false;
        cancelAnimationFrame(animationId);
        carousel.classList.remove('is-dragging');

        const slideWidth = getSlideWidth();
        const projected = currentTranslate + velocity * 180;
        const projectedIndex = Math.round(-projected / slideWidth);
        currentIndex = Math.max(0, Math.min(slideCount - 1, projectedIndex));

        goToIndex();
        startAutoplay();
      }

      carousel.addEventListener('pointerdown', touchStart);
      carousel.addEventListener('pointermove', touchMove);
      carousel.addEventListener('pointerup', touchEnd);
      carousel.addEventListener('pointercancel', touchEnd);

      carousel.addEventListener('contextmenu', (e) => {
        if (isDragging) e.preventDefault();
      });

      window.addEventListener('resize', () => {
        goToIndex(false);
      });

      startAutoplay();
    });
  }

  initFullbleedCarousels();
</script>
