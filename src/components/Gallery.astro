---
import { Image } from 'astro:assets';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;
const [p1, p2, p3, p4] = projects;
---

<section class="fgal reveal">
  <div class="fgal__canvas">

    <div class="fgal__slot fgal__slot--1">
      <div class="fgal__drift-layer fgal__drift-layer--1">
        <div class="fgal__scale-wrap">
          <a href={p1.page} class="fgal__item fgal__item--pink">
            <div class="fgal__image-wrap">
              <Image src={`${p1.gallerySrc ?? p1.thumbnail}?w=900&q=85&fl=progressive`} alt={p1.title} inferSize />
            </div>
            <div class="fgal__mask" aria-hidden="true">
              <svg viewBox="0 0 450 360" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <mask id="fgal-mask-pink">
                    <rect width="450" height="360" fill="white"/>
                    <path fill="black" d="M 39 0 C 39 0 117 58 235 58 C 354 58 432 0 432 0 C 432 0 432 98 432 148 C 432 198 432 310 432 310 C 432 310 333 266 235 266 C 138 266 39 310 39 310 C 39 310 97 208 97 148 C 97 88 39 0 39 0 Z"/>
                  </mask>
                </defs>
                <rect width="450" height="360" fill="#ff4d7e" mask="url(#fgal-mask-pink)"/>
              </svg>
            </div>
          </a>
          <p class="fgal__caption">{p1.title}</p>
        </div>
      </div>
    </div>

    <div class="fgal__slot fgal__slot--2">
      <div class="fgal__drift-layer fgal__drift-layer--2">
        <div class="fgal__scale-wrap">
          <a href={p2.page} class="fgal__item fgal__item--blue">
            <div class="fgal__image-wrap">
              <Image src={`${p2.gallerySrc ?? p2.thumbnail}?w=900&q=85&fl=progressive`} alt={p2.title} inferSize />
            </div>
            <div class="fgal__mask" aria-hidden="true">
              <svg viewBox="0 0 787 520" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <mask id="fgal-mask-blue">
                    <rect width="787" height="520" fill="white"/>
                    <ellipse cx="490" cy="258" rx="218" ry="218" fill="black"/>
                    <rect x="690" y="40" width="72" height="436" fill="black"/>
                  </mask>
                </defs>
                <rect width="787" height="520" fill="#0557fa" mask="url(#fgal-mask-blue)"/>
              </svg>
            </div>
          </a>
          <p class="fgal__caption">{p2.title}</p>
        </div>
      </div>
    </div>

    <div class="fgal__slot fgal__slot--3">
      <div class="fgal__drift-layer fgal__drift-layer--3">
        <div class="fgal__scale-wrap">
          <a href={p3.page} class="fgal__item fgal__item--orange">
            <div class="fgal__image-wrap">
              <Image src={`${p3.gallerySrc ?? p3.thumbnail}?w=900&q=85&fl=progressive`} alt={p3.title} inferSize />
            </div>
            <div class="fgal__mask" aria-hidden="true">
              <svg viewBox="0 0 338 240" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <mask id="fgal-mask-orange">
                    <rect width="338" height="240" fill="white"/>
                    <ellipse cx="169" cy="228" rx="157" ry="157" fill="black"/>
                    <rect x="0" y="210" width="338" height="30" fill="white"/>
                  </mask>
                </defs>
                <rect width="338" height="240" fill="#ed9c31" mask="url(#fgal-mask-orange)"/>
              </svg>
            </div>
          </a>
          <p class="fgal__caption fgal__caption--right">{p3.title}</p>
        </div>
      </div>
    </div>

    <div class="fgal__slot fgal__slot--4">
      <div class="fgal__drift-layer fgal__drift-layer--4">
        <div class="fgal__scale-wrap">
          <a href={p4.page} class="fgal__item fgal__item--green">
            <div class="fgal__image-wrap">
              <Image src={`${p4.gallerySrc ?? p4.thumbnail}?w=900&q=85&fl=progressive`} alt={p4.title} inferSize />
            </div>
            <div class="fgal__mask" aria-hidden="true">
              <svg viewBox="0 0 503 320" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <mask id="fgal-mask-green">
                    <rect width="503" height="320" fill="white"/>
                    <polygon points="478,295 478,20.5 215,20.5" fill="black"/>
                  </mask>
                </defs>
                <rect width="503" height="320" fill="#008d5e" mask="url(#fgal-mask-green)"/>
              </svg>
            </div>
          </a>
          <p class="fgal__caption">{p4.title}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .fgal {
    padding-top: 80px;
  }

  .fgal__canvas {
    position: relative;
    max-width: 1056px;
    margin: 0 auto;
    aspect-ratio: 1320 / 1102;
  }

  /* ── Slots: position anchors ── */

  .fgal__slot {
    position: absolute;
  }

  /* Width only — height derives from the item's aspect-ratio in normal flow */
  .fgal__slot--1 { left: 0.3%;  top: 14.5%;  width: 34.1%; }
  .fgal__slot--2 { left: 40.4%; top: 0;      width: 59.6%; }
  .fgal__slot--3 { left: 14.7%; top: 57.80%; width: 25.6%; }
  .fgal__slot--4 { left: 47.1%; top: 61.43%; width: 38.1%; }

  /* ── Drift layer: normal-flow block, transform only ── */

  .fgal__drift-layer {
    transform-origin: center center;
  }

  /* ── Scale wrap: contains item + caption, establishes stacking context ── */

  .fgal__scale-wrap {
    position: relative;
    transform-origin: center center;
    /* Start tiny; JS opens each item in load sequence */
    transform: scale(0.07);
  }

  /* ── Item: in normal flow, sets its own height via aspect-ratio ── */

  .fgal__item {
    position: relative;
    width: 100%;
    display: block;
    overflow: hidden;
    text-decoration: none;
    border-bottom: none;
  }

  .fgal__item--pink   { aspect-ratio: 450 / 360; }
  .fgal__item--blue   { aspect-ratio: 787 / 520; }
  .fgal__item--orange { aspect-ratio: 338 / 240; }
  .fgal__item--green  { aspect-ratio: 503 / 320; }

  /* ── Image layer ── */

  .fgal__image-wrap {
    position: absolute;
    inset: 0;
  }

  .fgal__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform-origin: center;
  }

  /* Per-slot image positioning */
  .fgal__slot--2 .fgal__image-wrap img { object-position: 60% 15%; }
  .fgal__slot--4 .fgal__image-wrap img {
    object-position: center 65%;
    transform: scale(1.6) translateX(5%) translateY(30%);
    transform-origin: center center;
  }

  /* ── Mask layer ── */

  .fgal__mask {
    position: absolute;
    inset: -1px;
    pointer-events: none;
    overflow: hidden;
  }

  .fgal__mask svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Captions: below item, inside scale-wrap ── */

  .fgal__caption {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    margin: 0;
    padding-top: 14px;
    font-size: clamp(10px, 1.38vw, 18px);
    line-height: 1.1;
    color: #EFF0EC;
  }

  .fgal__caption--right {
    text-align: right;
  }

  /* ── Drift animations (start paused; JS resumes after load) ── */

  .fgal__drift-layer--1 {
    animation: drift-1 4.3s ease-in-out infinite alternate -0.7s;
    animation-play-state: paused;
  }
  .fgal__drift-layer--2 {
    animation: drift-2 5.1s ease-in-out infinite alternate -1.9s;
    animation-play-state: paused;
  }
  .fgal__drift-layer--3 {
    animation: drift-3 4.7s ease-in-out infinite alternate -2.8s;
    animation-play-state: paused;
  }
  .fgal__drift-layer--4 {
    animation: drift-4 3.9s ease-in-out infinite alternate -1.1s;
    animation-play-state: paused;
  }

  @keyframes drift-1 {
    from { transform: translate(0, 0); }
    40%  { transform: translate(8px, -10px); }
    to   { transform: translate(13px, -5px); }
  }
  @keyframes drift-2 {
    from { transform: translate(0, 0); }
    55%  { transform: translate(-14px, 6px); }
    to   { transform: translate(-9px, 12px); }
  }
  @keyframes drift-3 {
    from { transform: translate(0, 0); }
    35%  { transform: translate(10px, -8px); }
    to   { transform: translate(6px, -13px); }
  }
  @keyframes drift-4 {
    from { transform: translate(0, 0); }
    60%  { transform: translate(-11px, -5px); }
    to   { transform: translate(-15px, -9px); }
  }

  /* ── Reduced motion ── */

  @media (prefers-reduced-motion: reduce) {
    .fgal__scale-wrap {
      transform: scale(1) !important;
      transition: none !important;
    }
    .fgal__drift-layer {
      animation: none !important;
    }
  }

  /* ── Responsive ── */

  @media screen and (max-width: 767px) {
    .fgal {
      padding-top: 40px;
    }
  }
</style>

<script>
  (() => {
    const canvas = document.querySelector<HTMLElement>('.fgal__canvas');
    if (!canvas) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas.querySelectorAll<HTMLElement>('.fgal__scale-wrap').forEach(sw => {
        sw.style.transition = 'none';
        sw.style.transform  = 'scale(1)';
      });
      return;
    }

    const slots  = Array.from(canvas.querySelectorAll<HTMLElement>('.fgal__slot'));
    const drifts = Array.from(canvas.querySelectorAll<HTMLElement>('.fgal__drift-layer'));
    const wraps  = Array.from(canvas.querySelectorAll<HTMLElement>('.fgal__scale-wrap'));

    type Pos = { left: string; top: string };

    // Home positions (match CSS .fgal__slot--N)
    const HOME: Pos[] = [
      { left: '0.3%',   top: '14.52%' },  // i1 pink
      { left: '40.38%', top: '0%'     },  // i2 blue
      { left: '14.7%',  top: '57.80%' },  // i3 orange
      { left: '47.12%', top: '61.43%' },  // i4 green
    ];

    // i2 ↔ i3 swap — all 4 move (Figma Group 69) to avoid blue card overlapping i4
    const SWAP_23: Pos[] = [
      { left: '19.39%', top: '0%'     },  // i1 pink
      { left: '0%',     top: '47.46%' },  // i2 blue
      { left: '65.91%', top: '12.70%' },  // i3 orange
      { left: '66.21%', top: '51.09%' },  // i4 green
    ];

    const HOLD_MS    = 16000;
    const CLOSE_MS   = 350;
    const OPEN_MS    = 500;
    const STAGGER_MS = 200;

    const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

    function setPos(slotEl: HTMLElement, p: Pos) {
      slotEl.style.left  = p.left;
      slotEl.style.top   = p.top;
      slotEl.style.right = '';
    }

    function openWrap(el: HTMLElement) {
      el.style.transition = `transform ${OPEN_MS}ms cubic-bezier(0.22, 0, 0, 1)`;
      el.style.transform  = 'scale(1)';
    }

    function closeWrap(el: HTMLElement) {
      el.style.transition = `transform ${CLOSE_MS}ms ease-in`;
      el.style.transform  = 'scale(0.07)';
    }

    async function moveItems(indices: number[], positions: Pos[]) {
      indices.forEach(i => {
        drifts[i].style.animationPlayState = 'paused';
        closeWrap(wraps[i]);
      });
      await sleep(CLOSE_MS);
      indices.forEach((i, j) => setPos(slots[i], positions[j]));
      indices.forEach(i => openWrap(wraps[i]));
      await sleep(OPEN_MS);
      indices.forEach(i => { drifts[i].style.animationPlayState = 'running'; });
    }

    async function run() {
      // Load: i1(0) → i4(3) → i2(1) → i3(2), staggered
      for (const idx of [0, 3, 1, 2]) {
        openWrap(wraps[idx]);
        await sleep(STAGGER_MS);
      }
      await sleep(OPEN_MS);

      drifts.forEach(d => { d.style.animationPlayState = 'running'; });

      while (true) {
        await sleep(HOLD_MS);
        await moveItems([0, 1, 2, 3], SWAP_23);              // i2 ↔ i3 (all 4 move)
        await sleep(HOLD_MS);
        await moveItems([0, 1, 2, 3], HOME);                  // back to home
        await sleep(HOLD_MS);
        await moveItems([0, 3], [HOME[3], HOME[0]]);          // i1 ↔ i4
        await sleep(HOLD_MS);
        await moveItems([0, 3], [HOME[0], HOME[3]]);          // i1 ↔ i4 back
      }
    }

    run();
  })();
</script>
