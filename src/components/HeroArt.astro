---
// Abstract geometric composition — each shape is independently animatable
// Uses individual transform properties (translate, rotate, scale) so
// entrance transitions and float animations don't conflict.
---

<div class="hero-art" aria-hidden="true">
  <div class="hero-art__shape hero-art__rect hero-art__rect--orange"></div>
  <div class="hero-art__shape hero-art__circle hero-art__circle--right"></div>
  <div class="hero-art__shape hero-art__rect hero-art__rect--pink"></div>
  <div class="hero-art__shape hero-art__rect hero-art__rect--blue"></div>
  <div class="hero-art__shape hero-art__circle hero-art__circle--lower"></div>
  <div class="hero-art__shape hero-art__circle hero-art__circle--upper"></div>
</div>

<style>
  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 854 / 866;
    overflow: visible;
  }

  .hero-art__shape {
    position: absolute;
    will-change: translate, opacity;
    opacity: 0;
    transition: opacity 2s ease;
  }

  .hero-art.is-loaded .hero-art__shape {
    opacity: 1;
  }

  .hero-art__shape:nth-child(1) { transition-delay: 0.2s; }
  .hero-art__shape:nth-child(2) { transition-delay: 0.35s; }
  .hero-art__shape:nth-child(3) { transition-delay: 0.5s; }
  .hero-art__shape:nth-child(4) { transition-delay: 0.65s; }
  .hero-art__shape:nth-child(5) { transition-delay: 0.8s; }
  .hero-art__shape:nth-child(6) { transition-delay: 0.95s; }

  .hero-art__circle {
    border-radius: 50%;
    background: linear-gradient(
      0deg,
      rgba(0, 141, 94, 0) 0%,
      rgba(95, 158, 229, 1) 46.35%,
      rgba(255, 178, 178, 1) 78.13%,
      rgba(242, 222, 220, 1) 100%
    );
  }

  .hero-art__rect--orange {
    width: 39.84%;
    height: 18.69%;
    background: #ff864d;
    left: 69.9%;
    top: 19.1%;
    rotate: -148deg;
    translate: -50% -50%;
    animation: float-1 9s ease-in-out infinite;
  }

  .hero-art__circle--right {
    width: 34.43%;
    height: 33.94%;
    left: 80.9%;
    top: 34.3%;
    rotate: 95.67deg;
    translate: -50% -50%;
    animation: float-2 11s ease-in-out infinite;
  }

  .hero-art__rect--pink {
    width: 39.84%;
    height: 18.69%;
    background: #ff4d7e;
    left: 21.7%;
    top: 26.9%;
    rotate: 135.74deg;
    translate: -50% -50%;
    animation: float-3 10s ease-in-out infinite;
  }

  .hero-art__rect--blue {
    width: 39.84%;
    height: 18.69%;
    background: #0055dd;
    left: 71.0%;
    top: 78.4%;
    rotate: -102.09deg;
    translate: -50% -50%;
    animation: float-4 8s ease-in-out infinite;
  }

  .hero-art__circle--lower {
    width: 34.43%;
    height: 33.94%;
    left: 58.7%;
    top: 73.4%;
    rotate: 24.88deg;
    translate: -50% -50%;
    animation: float-5 12s ease-in-out infinite;
  }

  .hero-art__circle--upper {
    width: 34.43%;
    height: 33.94%;
    left: 36.4%;
    top: 35.3%;
    rotate: -179.24deg;
    translate: -50% -50%;
    animation: float-6 13s ease-in-out infinite;
  }

  @keyframes float-1 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% + 8px) calc(-50% - 10px); }
    66% { translate: calc(-50% - 6px) calc(-50% + 5px); }
  }

  @keyframes float-2 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% - 7px) calc(-50% + 9px); }
    66% { translate: calc(-50% + 5px) calc(-50% - 4px); }
  }

  @keyframes float-3 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% + 5px) calc(-50% + 8px); }
    66% { translate: calc(-50% - 9px) calc(-50% - 6px); }
  }

  @keyframes float-4 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% - 10px) calc(-50% - 7px); }
    66% { translate: calc(-50% + 4px) calc(-50% + 9px); }
  }

  @keyframes float-5 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% + 9px) calc(-50% - 5px); }
    66% { translate: calc(-50% - 3px) calc(-50% + 11px); }
  }

  @keyframes float-6 {
    0%, 100% { translate: -50% -50%; }
    33% { translate: calc(-50% - 6px) calc(-50% + 7px); }
    66% { translate: calc(-50% + 10px) calc(-50% - 8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-art__shape {
      animation: none !important;
      opacity: 1 !important;
      transition: none !important;
      translate: -50% -50% !important;
    }
  }

  @media screen and (max-width: 991px) {
    .hero-art {
      border-radius: 4px;
      max-width: 400px;
      margin: 30px auto 0;
    }
  }
</style>

<script>
  requestAnimationFrame(() => {
    document.querySelector('.hero-art')?.classList.add('is-loaded');
  });
</script>
