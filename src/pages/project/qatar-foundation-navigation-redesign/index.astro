---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import projects from '../../../data/projects.yaml';
import ProjectHero from '../../../components/ProjectHero.astro';
import ProjectMeta from '../../../components/ProjectMeta.astro';
import TextBlock from '../../../components/TextBlock.astro';
import ImageCentered from '../../../components/ImageCentered.astro';
import ImageFullBleed from '../../../components/ImageFullBleed.astro';
import GridFullCenter from '../../../components/GridFullCenter.astro';
import ImageCarousel from '../../../components/ImageCarousel.astro';
import ImageSlideshow from '../../../components/ImageSlideshow.astro';
import FullBleedSlideshow from '../../../components/FullBleedSlideshow.astro';
import ProjectNextFooter from '../../../components/ProjectNextFooter.astro';

const project = projects.qf;
const research_slides = project.research;
const case_slides = project.case;
const display_slides = project.display;
---

<BaseLayout title="Qatar Foundation – Navigation redesign">
  <ProjectHero imageUrl={project.hero} title="Qatar Foundation – Navigation redesign" />
  <TextBlock
    heading="Challenge"
    text="Qatar Foundation is a unique non-profit organization from Qatar. With around 50 entities working in education, research and community development. After a successful website redesign, they needed to revisit their website navigation to increase content discovery and findability for their wide range of audience."
  />
  <ProjectMeta client={project.client} toolkit={project.toolkit} />
  <ImageCentered
    imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/4nFf8YRrSwCiSQynuda04R/bfcac58dcd79cd9dec8c8e9f484967ab/Landing_page_G1_no_background_1.jpg"
    align="bottom"
    imageClass="rounded-top"
  />
  <ImageCarousel slides={case_slides} />
  <TextBlock
    heading="Solution"
    text="Designed a comprehensive navigation system for desktop which included global navigation, expanded local navigation and in-page navigation that did not compromise the minimal aesthetics of the existing Qatar Foundation website. For mobile users, I adopted the bottom navigation pattern to minimize the interaction cost of having the hamburger menu at the top of the screen."
  />
  <FullBleedSlideshow slides={display_slides} />
  <ImageCentered imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/7yzGWioK4vOvHuzm8Hm4I8/0bcb7aa3d4fbeb973934c40ab58dbfd9/Education_G1_L1_P1.jpg" />
  <GridFullCenter
    fullImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/avllZSMASu0fW2AjJQ6Rc/16e9e0938d593c31617dec1fd4d667aa/QF_Education.jpg"
    centerImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/6hxZT6bz5hrQ3peOjlft06/463ee87b994d02811eb4f97f1f9d9d0d/qf.org.qa_navigation_education_mobile.png"
  />
  <ImageSlideshow slides={research_slides} />
  <GridFullCenter
    fullImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/4RCNN0NlbnUyqOSmcwJavc/95c9b99ef7da37090289f98e6f351403/QF_Research.jpg"
    centerImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/ttnjruKj34y1oLIRCVEwg/6be7345d73bcccbe1343d2837b7ce534/qf.org.qa_navigation_mobile_research.png"
  />
  <ImageFullBleed imageUrl="https://images.ctfassets.net/2orm8gd3ce6v/79CGxtx0nhVjCA1FIvf8hN/d46ed783d8e90be33b7f0991c1239aa2/qf-community-tablet.jpg" />
  <TextBlock
    heading="Result"
    text="By making the global navigation clearly visible on all pages had an immediate effect. Qatar Foundation's digital team noticed an increase in engagement and lower bounce rates."
  />
  <GridFullCenter
    fullImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/s1OLI4dPoGh6Fjw4ipko4/e594afb2da7ebc614456c98fe8d8ba32/QF_Community.jpg"
    centerImageUrl="https://images.ctfassets.net/2orm8gd3ce6v/4JEwoA0CXr44qqE2LU66WV/e6231f05854f593e8f00b72d02d25131/qf.org.qa_navigation_mobile_community.png"
  />
  <ProjectNextFooter slot="footer" title={projects.healthdesk.title} url={projects.healthdesk.page} color={projects.healthdesk.color} />
</BaseLayout>
